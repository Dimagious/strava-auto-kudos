STRAVA_ATHLETE_ID=      # your profile number from strava.com/athletes/XXXXXXX
STRAVA_VERIFY_TOKEN=    # any random string you make up, e.g. kudos_bot_secret_42
PORT=3002
KUDOS_INTERVAL_HOURS=8  # how often to auto-check feed (in hours, min 1)

# Your browser session cookie — copy once from DevTools (Application → Cookies → _strava4_session)
# The bot auto-saves session renewals to session.txt, so this only needs to be set on first run
STRAVA_SESSION_COOKIE=
